# tevy2 Backend — Required Environment Variables
# Set these on Railway (or in .env for local dev)

# Stytch Auth
STYTCH_PROJECT_ID=project-test-xxx
STYTCH_SECRET=secret-test-xxx

# Supabase (DB only)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Infrastructure provider: "fly" or "docker"
INFRA_PROVIDER=docker

# Fly.io (only needed if INFRA_PROVIDER=fly)
FLY_API_TOKEN=fo1_xxx
FLY_APP_NAME=tevy2-agents
FLY_REGION=lhr

# Docker host (only needed if INFRA_PROVIDER=docker)
# Docker Engine API URL — expose via TCP (with TLS) or SSH tunnel
DOCKER_HOST_URL=http://localhost:2375
# Public URL where bots are reachable (host IP/domain)
DOCKER_HOST_PUBLIC_URL=http://localhost

# AI
ANTHROPIC_API_KEY=sk-ant-xxx
DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514

# Frontend URL (CORS)
FRONTEND_URL=https://tevy2-dashboard.netlify.app

# Optional
PORT=3001
TAVILY_API_KEY=
